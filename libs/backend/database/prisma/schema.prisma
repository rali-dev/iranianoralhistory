generator client {
  provider = "prisma-client"
  output   = "../../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  hashedPassword String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}


