# ─────────────────────────────────────────────────────────────
# Environment-Vorlage — kopiere nach ".env" und fülle echte Werte ein.
# Die echte ".env" wird NICHT eingecheckt (siehe .gitignore).
# ─────────────────────────────────────────────────────────────

# PostgreSQL-Verbindung
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/iranianoralhistory?schema=public"

# JWT-Signatur — je ein starker Zufallswert (mind. 32 Zeichen / 256 Bit).
# Erzeugen mit:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# NIEMALS triviale Werte wie "secret" verwenden — die App verweigert beim Start den Boot.
JWT_SECRET="<32+ Zeichen Zufallswert>"
JWT_REFRESH_SECRET="<32+ Zeichen Zufallswert, verschieden vom JWT_SECRET>"

# Resend (Transaktions-E-Mails)
RESEND_API_KEY="re_..."
# Test-Absender (ohne verifizierte Domain). Ersetze mit noreply@iranianoralhistory.de sobald die Domain bei Resend verifiziert ist.
RESEND_FROM_ADDRESS="onboarding@resend.dev"

# Supabase Storage — privates Bucket mit Signed URLs
# SUPABASE_URL:        Project Settings → General → Reference ID → https://<ref>.supabase.co
# SUPABASE_SECRET_KEY: Project Settings → API → Secret keys → Reveal → sb_secret_...
# SUPABASE_BUCKET:     Name deines Storage-Buckets
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_..."
SUPABASE_BUCKET="documents"
